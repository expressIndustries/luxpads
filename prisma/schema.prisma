// LuxPads — MySQL schema (Prisma 5)
// Domain: listing marketplace; owner listings are free (no platform subscription).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  renter
  owner
  admin
}

enum ListingStatus {
  draft
  pending_review
  published
  suspended
  archived
}

enum AvailabilityBlockType {
  /// Owner-marked open window for guests (shown as available on the listing calendar).
  available
  /// Hold / tentative — treat as unavailable for search and public calendar.
  booking_in_progress
  /// Confirmed booking or otherwise unavailable.
  booked
}

enum MessageSender {
  renter
  owner
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  name          String?
  phone         String?
  role          Role      @default(renter)
  suspended     Boolean   @default(false)
  /// Set when the user finishes the owner/renter welcome step (or upgrades to owner later via the same flow).
  welcomeCompletedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownerProfile           OwnerProfile?
  listings               Listing[]       @relation("OwnerListings")
  conversationsOwned     Conversation[]  @relation("OwnerConversations")
  conversationsAsRenter  Conversation[]  @relation("RenterConversations")
  favorites              Favorite[]
  adminActions   AdminAction[]   @relation("AdminActions")
  emailVerificationTokens EmailVerificationToken[]
  postVerifyLoginTokens   PostVerifyLoginToken[]
}

/// One-time link to confirm email after signup (Mailgun outbound).
model EmailVerificationToken {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String   @unique
  expiresAt    DateTime
  /// Path-only redirect after success (e.g. /listing/my-slug), validated in verify route.
  redirectPath String?  @db.VarChar(512)
  createdAt    DateTime @default(now())

  @@index([userId])
}

/// One-time token to establish a session immediately after clicking the email verification link (no password re-entry).
model PostVerifyLoginToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model OwnerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName  String
  bio          String?  @db.Text
  contactEmail String?
  contactPhone String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Listing {
  id                   String        @id @default(cuid())
  ownerId              String
  owner                User          @relation("OwnerListings", fields: [ownerId], references: [id], onDelete: Cascade)
  slug                 String        @unique
  title                String
  summary              String        @db.Text
  description          String        @db.Text
  propertyType         String

  addressLine1 String
  city         String
  state        String
  country      String  @default("United States")
  postalCode   String
  latitude     Float?
  longitude    Float?

  maxGuests  Int
  bedrooms   Int
  bathrooms  Float
  beds       Int

  sleepingArrangements String? @db.Text
  houseRules           String? @db.Text
  checkInOut           String? @db.Text
  cancellationPolicy   String? @db.Text

  nightlyRateCents Int
  cleaningFeeNote  String? @db.Text
  minNights        Int     @default(1)

  status   ListingStatus @default(draft)
  featured Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images         ListingImage[]
  amenities      ListingAmenity[]
  availability   AvailabilityBlock[]
  conversations  Conversation[]
  favorites      Favorite[]

  @@index([status, city])
  @@index([ownerId])
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String   @db.Text
  sortOrder Int      @default(0)
  alt       String?
  createdAt DateTime @default(now())

  @@index([listingId, sortOrder])
}

model Amenity {
  id        String           @id @default(cuid())
  slug      String           @unique
  label     String
  category  String?
  /// Higher values sort after lower; used to pin e.g. Golf access at end of checklist.
  sortOrder Int              @default(0)
  listings  ListingAmenity[]
}

model ListingAmenity {
  listingId String
  amenityId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([listingId, amenityId])
}

model AvailabilityBlock {
  id        String                  @id @default(cuid())
  listingId String
  listing   Listing                 @relation(fields: [listingId], references: [id], onDelete: Cascade)
  startDate DateTime                @db.Date
  endDate   DateTime                @db.Date
  type      AvailabilityBlockType   @default(available)
  note      String?
  createdAt DateTime                @default(now())

  @@index([listingId, startDate, endDate])
}

model Conversation {
  id              String    @id @default(cuid())
  listingId       String
  listing         Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User      @relation("OwnerConversations", fields: [ownerId], references: [id], onDelete: Cascade)
  renterName      String
  renterEmail     String
  renterPhone     String?
  renterUserId    String?
  renterUser      User?     @relation("RenterConversations", fields: [renterUserId], references: [id], onDelete: SetNull)
  checkIn         DateTime? @db.Date
  checkOut        DateTime? @db.Date
  guestCount      Int?
  /// Opaque token for Mailgun Reply-To: reply+{token}@mail.luxpads.co
  mailThreadToken String    @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  messages        Message[]

  @@unique([listingId, renterEmail])
  @@index([ownerId])
  @@index([renterUserId])
  @@index([listingId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderRole     MessageSender
  body           String        @db.Text
  createdAt      DateTime      @default(now())
  readByOwnerAt  DateTime?
  readByRenterAt DateTime?

  @@index([conversationId, createdAt])
}

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation("AdminActions", fields: [adminId], references: [id])
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model FeaturedDestination {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  subtitle  String?
  imageUrl  String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
}
