# Copy to .env — never commit real secrets.

# App (production: https://luxpads.co)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=LuxPads

# Database (MySQL 8)
# Local dev (MySQL in Docker, port mapped to host — see docker-compose.yml):
DATABASE_URL="mysql://luxpads:luxpads@localhost:23306/luxpads"
# LAMP / VPS (MySQL on same machine, no Docker): use the socket host, e.g.
# DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/luxpads"
# Docker Compose app + db containers: hostname must be `db`, e.g.
# DATABASE_URL="mysql://luxpads:luxpads@db:3306/luxpads"
# (or omit DATABASE_URL in .env and let docker-compose.yml default apply)

# phpMyAdmin: docker compose up -d phpmyadmin → http://localhost:18080 (override with PHPMYADMIN_PORT=)
# Default DB target is Compose service `db`. If MySQL runs on the host only (port 23306), use:
# PMA_HOST=host.docker.internal
# PMA_PORT=23306

# Auth.js / NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Listing workflow
# When true, owner "Publish" sends listing to pending_review for admin approval
REQUIRE_LISTING_APPROVAL=true

# Email — LuxPads messaging uses Mailgun (mail.luxpads.co)
# Outbound: Messages API. Inbound: Mailgun Route → POST /api/mailgun/inbound (this Next.js app).
MAILGUN_API_KEY=
# Sending domain (verified in Mailgun)
MAILGUN_DOMAIN=mail.luxpads.co
# From header (must be an address on MAILGUN_DOMAIN)
# MAILGUN_FROM=LuxPads <messages@mail.luxpads.co>
# Webhook signing key (Sending → Webhooks) — required to accept inbound mail
MAILGUN_WEBHOOK_SIGNING_KEY=
# EU region: MAILGUN_EU=true (uses api.eu.mailgun.net)
#
# Mailgun receiving: create a Route that matches e.g. match_recipient("reply+*@mail.luxpads.co")
# and forwards POST to https://luxpads.co/api/mailgun/inbound (forward with full MIME or "parsed").
#
# Legacy (not used for thread relay)
# SMTP_URL=smtps://user:pass@smtp.example.com:465
# RESEND_API_KEY=

# Listing photo storage (optional). Default: <app>/public/uploads (URLs stay /uploads/...).
# Use an absolute path + Docker volume when you run more than one app replica so every instance
# shares the same files (otherwise uploads 404 on requests that hit another machine).
# LUXPADS_UPLOADS_ROOT=/data/luxpads-uploads

# Maps (optional) — listing "Location" section; images load via /api/maps/static (server proxy).
# Prefer these (read at runtime — required for Docker images built without secrets):
# MAP_PROVIDER=google
# GOOGLE_MAPS_API_KEY=your_key_here
# MAPBOX_ACCESS_TOKEN=pk.ey...   # only if MAP_PROVIDER=mapbox
#
# Legacy (inlined at `next build` — empty in Docker unless you pass build-args / rebuild with .env):
# NEXT_PUBLIC_MAP_PROVIDER=google
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_key_here
#
# Google Cloud: enable "Maps Static API" (+ "Geocoding API" if centering by address only).
# The proxy calls Google from your server. Application restriction must be "IP addresses" (prod server IP)
# or "None" for local dev — NOT "HTTP referrers only" (that breaks server-side fetches).
# If you previously used a referrer-only key on <img src="maps.googleapis.com/...">, wrong port/domain
# also broke the image; the proxy avoids browser referrer issues once the key allows server use.
