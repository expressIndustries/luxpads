# Copy to .env — never commit real secrets.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=LuxStay Direct

# Database (PostgreSQL — use Docker: docker compose up -d db)
DATABASE_URL="postgresql://luxstay:luxstay@localhost:5432/luxstay?schema=public"

# Auth.js / NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Stripe (owner subscriptions only)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Default Stripe Price ID for the owner plan (create in Dashboard or use seed mock mode)
STRIPE_PRICE_ID_OWNER_MONTHLY=price_placeholder

# Listing workflow
# When true, owner "Publish" sends listing to pending_review for admin approval
REQUIRE_LISTING_APPROVAL=true

# Email (optional — empty = log to console in dev)
# SMTP_URL=smtps://user:pass@smtp.example.com:465
# RESEND_API_KEY=

# Maps (optional)
# NEXT_PUBLIC_MAP_PROVIDER=google
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
