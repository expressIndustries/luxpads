# Copy to .env — never commit real secrets.

# App (production: https://luxpads.co). Must be a full URL with protocol or the app can error on boot.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=LuxPads

# Database (MySQL 8)
# Host-side Prisma / `npm run dev` (MySQL published on host port 23306 from compose `db` service):
DATABASE_URL="mysql://luxpads:luxpads@localhost:23306/luxpads"
# Docker Compose **app** container ignores DATABASE_URL and uses db:3306 by default (see docker-compose.yml).
# To point the container at a different DB, set DOCKER_DATABASE_URL in .env.
# LAMP / VPS (MySQL on same machine, no Docker): use the real host, e.g.
# DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/luxpads"

# phpMyAdmin: docker compose up -d phpmyadmin → http://localhost:18080 (override with PHPMYADMIN_PORT=)
# Default DB target is Compose service `db`. If MySQL runs on the host only (port 23306), use:
# PMA_HOST=host.docker.internal
# PMA_PORT=23306

# Auth.js / NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Listing workflow
# When true, owner "Publish" sends listing to pending_review for admin approval
REQUIRE_LISTING_APPROVAL=true

# Email — LuxPads messaging uses Mailgun (mail.luxpads.co)
# Outbound: Messages API. Inbound: Mailgun Route → POST /api/mailgun/inbound (this Next.js app).
MAILGUN_API_KEY=
# Sending domain (verified in Mailgun)
MAILGUN_DOMAIN=mail.luxpads.co
# From header (must be an address on MAILGUN_DOMAIN)
# MAILGUN_FROM=LuxPads <messages@mail.luxpads.co>
# Webhook signing key (Sending → Webhooks) — required to accept inbound mail
MAILGUN_WEBHOOK_SIGNING_KEY=
# EU region: MAILGUN_EU=true (uses api.eu.mailgun.net)
#
# Mailgun receiving: create a Route that matches e.g. match_recipient("reply+*@mail.luxpads.co")
# and forwards POST to https://luxpads.co/api/mailgun/inbound (forward with full MIME or "parsed").
#
# Legacy (not used for thread relay)
# SMTP_URL=smtps://user:pass@smtp.example.com:465
# RESEND_API_KEY=

# Listing photo storage
#
# S3 (recommended in production): when AWS_BUCKET + AWS_DEFAULT_REGION are set, uploads go to
# s3://{AWS_BUCKET}/{AWS_S3_LISTING_PREFIX}/ (default prefix listing-images). Set object/bucket
# policy for public read, or front with CloudFront and set AWS_S3_PUBLIC_BASE_URL.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-west-2
# AWS_BUCKET=luxpads
# AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_S3_LISTING_PREFIX=listing-images
# AWS_S3_PUBLIC_BASE_URL=https://your-cdn.example.com   # optional; default virtual-hosted S3 URL
# NEXT_IMAGE_S3_HOSTS=cdn.example.com,other.cloudfront.net   # optional extra hostnames for next/image (comma-separated)
#
# next/image: hostnames are baked in at `next build` (see next.config). Docker: pass AWS_BUCKET + region as
# build args (docker-compose does this from .env) or set NEXT_IMAGE_S3_HOSTS before `docker compose build`.
#
# Local disk (fallback): URLs stay /uploads/... — use LUXPADS_UPLOADS_ROOT + Docker volume when you
# run multiple app replicas without S3.
# LUXPADS_UPLOADS_ROOT=/data/luxpads-uploads

# Maps (optional) — listing "Approximate Location".
# Prefer these (read at runtime — required for Docker images built without secrets):
# MAP_PROVIDER=google
# GOOGLE_MAPS_API_KEY=your_key_here
# MAPBOX_ACCESS_TOKEN=pk.ey...   # only if MAP_PROVIDER=mapbox
#
# Interactive Google map in the browser (when MAP_PROVIDER=google and lat/lng exist): the same key is
# passed to the Maps JavaScript API loader. Restrict that key for "HTTP referrers" (your site origins)
# or use NEXT_PUBLIC_GOOGLE_MAPS_API_KEY with referrer restrictions while GOOGLE_MAPS_API_KEY stays
# server-only (IP-restricted) for /api/maps/static.
#
# Legacy (inlined at `next build` — empty in Docker unless you pass build-args / rebuild with .env):
# NEXT_PUBLIC_MAP_PROVIDER=google
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_key_here
#
# Google Cloud: enable "Maps Static API" for the server proxy; enable "Maps JavaScript API" for the
# interactive listing map. Geocoding API if centering static maps by address only.
# Static proxy: application restriction "IP addresses" (prod server) or "None" for local dev — NOT
# "HTTP referrers only" (that breaks server-side fetches).
